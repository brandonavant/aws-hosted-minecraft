# Local-only connection details and secrets for this project.
# Copy to .env and fill in real values. NEVER commit the populated .env.
#
#   cp .env.example .env
#   $EDITOR .env

# SSH connection to the live LightSail Minecraft server.
# MC_SSH_HOST is the static IP or DNS name of the LightSail instance.
# MC_SSH_USER is the SSH login user (LightSail Ubuntu images default to "ubuntu").
# MC_SSH_KEY is the absolute or relative path to the PEM private key file.
#   The PEM file itself MUST be gitignored (*.pem is excluded by default).
MC_SSH_HOST=<lightsail-static-ip-or-dns-name>
MC_SSH_USER=<ssh-username>
MC_SSH_KEY=<path-to-pem-file>
